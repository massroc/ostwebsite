---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const entry = await getEntry("pages", "index");
const { Content } = entry ? await render(entry) : { Content: null as any };
---
<BaseLayout
  title="Open Systems Theory"
  description={entry?.data.summary ?? "A learning resource for those interested in Open Systems Theory."}
>
  <article class="prose">
    {Content && <Content />}
  </article>
</BaseLayout>
