---
import { buildNav } from "../lib/nav";
const nav = await buildNav();
const here = Astro.url.pathname;
---

<header class="border-b border-ink-200 bg-white">
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-6 px-6 py-4">
    <a href="/" class="font-serif text-xl font-bold tracking-tight text-ink-900 hover:text-brand-600">
      Open Systems Theory
    </a>
    <nav class="hidden md:block" aria-label="Primary">
      <ul class="flex items-center gap-6 text-sm">
        {nav.map((section) => (
          <li class="group relative">
            <a
              href={section.href}
              class:list={[
                "py-2 transition-colors hover:text-brand-600",
                here.startsWith(section.href) && section.href !== "/"
                  ? "text-brand-600"
                  : "text-ink-700",
              ]}
            >
              {section.label}
            </a>
            {section.items.length > 0 && (
              <ul
                class="invisible absolute left-0 top-full z-10 min-w-56 rounded border border-ink-200 bg-white p-2 opacity-0 shadow-lg transition group-hover:visible group-hover:opacity-100"
              >
                {section.items.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class="block rounded px-3 py-2 text-ink-700 hover:bg-brand-50 hover:text-brand-700"
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
